<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <h1><%= pet.name %></h1>
    <div class="detail-grid">
      <div>
        <p><strong>Espécie:</strong> <%= pet.species %></p>
        <p><strong>Raça:</strong> <%= pet.breed || '-' %></p>
        <p><strong>Gênero:</strong> <%= pet.gender || '-' %></p>
        <p><strong>Data de nascimento:</strong> <%= pet.birthDate || '-' %></p>
      </div>
      <div>
        <p><strong>Responsável:</strong> <%= pet.ownerName || '-' %></p>
        <p><strong>Endereço:</strong> <%= pet.ownerAddress || '-' %></p>
        <p><strong>Contato:</strong> <%= pet.ownerPhone || '-' %></p>
      </div>
    </div>

    <section>
      <h2>Vacinas</h2>
      <% if (pet.vaccines.length === 0) { %>
        <p>Nenhuma vacina registrada.</p>
      <% } else { %>
        <ul>
          <% pet.vaccines.forEach((vaccine) => { %>
            <li><strong><%= vaccine.name || 'Vacina' %></strong> - aplicada em <%= vaccine.appliedDate || '-' %>, próxima em <%= vaccine.nextDate || '-' %></li>
          <% }) %>
        </ul>
      <% } %>
      <p><strong>Alerta de vacina:</strong> <%= pet.nextVaccineAlertDays %> dias antes</p>
    </section>

    <section>
      <h2>Banho e Tosa</h2>
      <p><strong>Último banho:</strong> <%= pet.bathDate || '-' %></p>
      <p><strong>Última tosa:</strong> <%= pet.groomingDate || '-' %></p>
    </section>

    <section>
      <h2>Serviço</h2>
      <p><strong>Local:</strong> <%= pet.serviceLocation || '-' %></p>
      <p><strong>Contato:</strong> <%= pet.serviceContact || '-' %></p>
      <p><strong>Saída:</strong> <%= pet.serviceDeparture || '-' %></p>
      <p><strong>Chegada:</strong> <%= pet.serviceReturn || '-' %></p>
    </section>

    <section>
      <h2>Observações</h2>
      <p><%= pet.notes || '-' %></p>
    </section>

    <div class="actions">
      <a class="button" href="/pets">Voltar</a>
      <a class="button button-secondary" href="/pets/<%= pet.id %>/edit">Editar</a>
    </div>
  </main>
</body>
</html>
